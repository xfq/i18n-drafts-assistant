PORT=3000
INDEX_PATH=.data/index.json
QUERY_LOG_PATH=.data/query-log.jsonl

SOURCE_MODE=git
SOURCE_REPO_URL=https://github.com/w3c/i18n-drafts.git
SOURCE_REF=gh-pages
SOURCE_CACHE_DIR=.cache/source/i18n-drafts
SOURCE_FETCH_DEPTH=1
SOURCE_REFRESH_MODE=manual

# Required only when SOURCE_MODE=local
SOURCE_REPO_PATH=/path/to/i18n-drafts

PUBLIC_BASE_URL=https://www.w3.org/International

# Multi-source configuration (optional).
# When set, overrides the single-source settings above.
# Accepts a JSON array of source objects. Each source supports:
#   id             — unique identifier (required)
#   mode           — "git" or "local" (default: "git")
#   repoUrl        — Git remote URL (git mode)
#   ref            — branch/ref to check out (default: "gh-pages")
#   cacheDir       — local cache directory (git mode)
#   fetchDepth     — shallow clone depth (default: 1)
#   repoPath       — local path (local mode)
#   publicBaseUrl  — base URL for canonical links (required)
#   contentRoots   — array of top-level directories to index (default: built-in set; use [""] for root)
#   requireMetadata — require W3C f-metadata in HTML pages (default: true)
#
SOURCES=[{"id":"i18n-drafts","repoUrl":"https://github.com/w3c/i18n-drafts.git","ref":"gh-pages","cacheDir":".cache/source/i18n-drafts","publicBaseUrl":"https://www.w3.org/International"},{"id":"bp-i18n-specdev","repoUrl":"https://github.com/w3c/bp-i18n-specdev.git","ref":"gh-pages","cacheDir":".cache/source/bp-i18n-specdev","publicBaseUrl":"https://w3c.github.io/bp-i18n-specdev","contentRoots":[""],"requireMetadata":false}]

# Default local mode is extractive and does not call a model provider.
MODEL_PROVIDER=local
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_TIMEOUT_MS=30000
EMBEDDING_MODEL=local-hashed-vector
GENERATION_MODEL=

DATABASE_URL=.data/index.json
ENABLE_DEBUG=false

# Set this to enable POST /api/admin/reindex with x-admin-token.
ADMIN_TOKEN=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Comma-separated proxy IPs/CIDRs whose Forwarded/X-Forwarded-For headers are trusted.
# Leave empty for direct-to-node deployments.
TRUSTED_PROXIES=
