{
  "name": "i18n-drafts-assistant",
  "version": "0.1.0",
  "private": true,
  "license": "See LICENSE in the project root for license information",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "node --test tests/*.test.js",
    "coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-include='public/**/*.js' tests/*.test.js",
    "index": "node src/indexing/indexer.js",
    "rag:index": "node src/indexing/indexer.js",
    "eval": "node src/evals/run.js"
  },
  "engines": {
    "node": "24.x"
  }
}
